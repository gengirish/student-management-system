# PostgreSQL (docker-compose)
POSTGRES_USER=sms
POSTGRES_PASSWORD=sms_secret
POSTGRES_DB=student_mgmt

# Backend — use this form for SQLAlchemy + psycopg2
DATABASE_URL=postgresql+psycopg2://sms:sms_secret@localhost:5432/student_mgmt

# JWT signing (use a long random string in production)
SECRET_KEY=replace-with-openssl-rand-hex-32

# Public URL of the API (used for profile image links in JSON responses)
PUBLIC_BASE_URL=http://localhost:8000

# Frontend build / browser — must match where the FastAPI server is reachable from the user’s browser
VITE_API_URL=http://localhost:8000
